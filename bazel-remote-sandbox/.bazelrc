###############################################################################
# .bazelrc — Bazel configuration for bazel_remote_sandbox
###############################################################################

# ── Common settings ──────────────────────────────────────────────────────────
common --color=yes
common --show_progress_rate_limit=1

# ── Build profiling ─────────────────────────────────────────────────────────
# Generates a JSON execution profile that can be loaded in Chrome's
# chrome://tracing or https://ui.perfetto.dev to visualize a Gantt chart
# of the build's critical path and action execution timeline.
build --profile=profile.json.gz

# ── Remote cache configuration ──────────────────────────────────────────────
# Activate with: bazel build --config=remote_cache //...
#
# Points at the local bazel-remote HTTP cache running in Docker
# (see docker-compose.yml).
build:remote_cache --remote_cache=http://localhost:8080
build:remote_cache --remote_upload_local_results=true
build:remote_cache --remote_download_toplevel
